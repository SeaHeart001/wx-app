page {
  min-height: 100vh;
  background: #f2f5fb;
  color: #172026;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  margin: 0 !important;
  padding: 0;
  box-sizing: border-box;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: normal;
  text-align: inherit;
}

button::after {
  border: none;
}

.button-hover {
  opacity: 0.86;
}
