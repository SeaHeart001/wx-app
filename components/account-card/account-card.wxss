.top-card {
  position: relative;
  overflow: hidden;
  padding: 34rpx 30rpx 32rpx;
  border-radius: 22rpx;
  background: linear-gradient(150deg, #1e40af 0%, #2563eb 55%, #7c3aed 100%);
}

.top-card::before,
.top-card::after {
  content: "";
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
}

.top-card::before {
  width: 300rpx;
  height: 300rpx;
  left: -120rpx;
  top: 86rpx;
}

.top-card::after {
  width: 230rpx;
  height: 230rpx;
  right: -70rpx;
  top: -80rpx;
}

.top-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.top-avatar {
  width: 96rpx !important;
  height: 96rpx;
  margin: 0;
  padding: 0;
  border-radius: 48rpx;
  background: transparent;
  overflow: visible;
  line-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-avatar::after {
  border: 0;
}

.avatar-image,
.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.78);
  box-sizing: border-box;
  flex: 0 0 auto;
}

.avatar-image {
  display: block;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.86);
  font-size: 34rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.14);
}

.top-meta {
  flex: 1;
  min-width: 0;
}

.welcome {
  display: block;
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
}

.user-name {
  display: block;
  margin-top: 0;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-name-logged {
  margin-top: 8rpx;
}

.status-panel {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 18rpx;
  margin-top: 38rpx;
}

.status-item {
  flex: 1;
  min-width: 0;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.13);
}

.status-label,
.status-value {
  display: block;
}

.status-label {
  color: rgba(255, 255, 255, 0.55);
  font-size: 23rpx;
}

.status-value {
  margin-top: 10rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 700;
}

.profile-card {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  padding: 4rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.94);
}

.profile-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 78rpx;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.08);
}

.profile-line:last-child {
  border-bottom: 0;
}

.profile-label {
  color: #8b95a7;
  font-size: 25rpx;
}

.profile-value {
  min-width: 0;
  flex: 1;
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
  text-align: right;
  word-break: break-all;
}
